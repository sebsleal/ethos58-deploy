{
  "appId": "com.ethos85.app",
  "appName": "Ethos85",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1800,
      "launchAutoHide": true,
      "backgroundColor": "#0F172A",
      "showSpinner": false
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DEFAULT"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DEFAULT"
    }
  }
}
